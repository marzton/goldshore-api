---
const links = [
  { label: 'Goldshore API Docs', href: 'https://docs.goldshore.com' },
  { label: 'Status Page', href: 'https://status.goldshore.com' },
  { label: 'Support', href: 'mailto:support@goldshore.com' }
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Goldshore Platform</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        color-scheme: light dark;
        font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: radial-gradient(circle at top left, #0f172a, #020617 60%);
        color: rgba(255, 255, 255, 0.92);
        min-height: 100%;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 2rem;
      }

      main {
        max-width: 36rem;
        text-align: center;
        background: rgba(15, 23, 42, 0.8);
        border: 1px solid rgba(148, 163, 184, 0.35);
        border-radius: 1.5rem;
        padding: 3rem 2.5rem;
        box-shadow: 0 20px 60px rgba(15, 23, 42, 0.45);
        backdrop-filter: blur(12px);
      }

      h1 {
        font-size: clamp(2.5rem, 5vw, 3rem);
        margin-bottom: 0.75rem;
        font-weight: 600;
      }

      p {
        margin: 0.5rem 0 2rem;
        color: rgba(226, 232, 240, 0.85);
        font-size: 1.05rem;
      }

      ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 0.75rem;
      }

      a {
        display: block;
        padding: 0.85rem 1rem;
        border-radius: 0.85rem;
        background: rgba(79, 70, 229, 0.14);
        border: 1px solid rgba(129, 140, 248, 0.4);
        color: inherit;
        text-decoration: none;
        font-weight: 500;
        transition: transform 0.2s ease, background 0.2s ease, border 0.2s ease;
      }

      a:hover,
      a:focus-visible {
        transform: translateY(-2px);
        background: rgba(129, 140, 248, 0.25);
        border-color: rgba(196, 181, 253, 0.75);
      }

      footer {
        margin-top: 2rem;
        font-size: 0.85rem;
        color: rgba(148, 163, 184, 0.7);
      }

      @media (max-width: 600px) {
        main {
          padding: 2.5rem 1.75rem;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Goldshore</h1>
      <p>Build, monitor, and scale your data pipelines with Goldshore&apos;s managed platform.</p>
      <ul>
        {links.map(({ label, href }) => (
          <li>
            <a href={href}>{label}</a>
          </li>
        ))}
      </ul>
      <footer>&copy; {new Date().getFullYear()} Goldshore</footer>
    </main>
  </body>
</html>

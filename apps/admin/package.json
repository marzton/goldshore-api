{
  "name": "@goldshore/apps-admin",
  "description": "Gold Shore Labs admin console derived from Cloudflare's saas-admin-template",
  "private": true,
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "dev": "astro dev --host --port 4321",
    "preview": "astro preview",
    "typecheck": "astro check",
    "cf:typegen": "wrangler types --config wrangler.jsonc",
    "db:migrate": "wrangler d1 migrations apply DB --local --config wrangler.jsonc",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote --config wrangler.jsonc",
    "db:reset": "wrangler d1 migrations reset DB --local --config wrangler.jsonc",
    "test": "tsx --test src/lib/utils/subscription.test.ts"
  },
  "dependencies": {
    "@astrojs/cloudflare": "12.6.0",
    "@astrojs/react": "4.3.0",
    "@astrojs/tailwind": "6.0.2",
    "@hookform/resolvers": "5.1.1",
    "@radix-ui/react-accordion": "1.2.7",
    "@radix-ui/react-dialog": "1.1.10",
    "@radix-ui/react-label": "2.1.4",
    "@radix-ui/react-navigation-menu": "1.2.9",
    "@radix-ui/react-slot": "1.2.0",
    "@tanstack/react-table": "8.21.3",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "astro": "5.14.8",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.525.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "7.58.1",
    "tailwind-merge": "3.3.1",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "1.0.7",
    "zod": "3.25.67"
  },
  "devDependencies": {
    "wrangler": "^4.42.2",
    "tsx": "^4.19.2"
  }
}

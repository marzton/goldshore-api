    "webhook_url": "https://api.goldshore.org/webhook/github",
    "setup_url": "https://admin.goldshore.org/setup/github",
    "oauth_callback_url": "https://api.goldshore.org/oauth/github/callback"
  },

  "github_oauth": {
    "GITHUB_CLIENT_ID": "<github_oauth_client_id>",
    "GITHUB_CLIENT_SECRET": "<github_oauth_client_secret>",
    "redirect_uri": "https://api.goldshore.org/oauth/github/callback",
    "scopes": ["read:user", "user:email"]

{
  "meta": {
    "project": ["**THIS**", "goldshore-gateway"],
    "version": ["1.0.0", "2025.11.03"],
    "description": [
      "Generation and source instructions for empty values in env.secrets.bundle.json",
      "Unified configuration for Cloudflare Workers Gateway, GitHub App, AI providers, Routes, and Empty-Field Integration Map."
    ]
  },

  "global": {},

  "cloudflare": {
    "CLOUDFLARE_ACCOUNT_ID": "<cloudflare_account_id>",

    "CLOUDFLARE_ZONE_ID": "<cloudflare_zone_id>",
    "zone_id": "<cloudflare_zone_id>",

    "CLOUDFLARE_API_TOKEN": "<cloudflare_api_token>",
    "api_token": "",

    "CLOUDFLARE_GLOBAL_API_KEY": "<cloudflare_global_api_key>",
    "global_key": "<cloudflare_global_api_key>",

    "CF_CA_ORIGIN_KEY": "<cloudflare_cf_ca_origin_key>",
    "origin_ca_key": "<cloudflare_cf_ca_origin_key>",

    "CLOUDFLARE_JWKS_URI": "https://goldshore.cloudflareaccess.com/cdn-cgi/access/certs",
    "jwks_uri": "https://goldshore.cloudflareaccess.com/cdn-cgi/access/certs",

    "ACCESS_AUDIENCE": "<cloudflare_access_audience>",

    "CF_PAGES_PROJECT_WEB": "goldshore-web",
    "CF_PAGES_PROJECT_ADMIN": "goldshore-admin",

    "pages_projects": {
      "web": "goldshore-web",
      "admin": "goldshore-admin"
    },

    "workers": {
      "edit_worker_token": "",
      "edit_dns_token": "",
      "all_resources_token": ""
    },

    "access": {
      "client_id": "<cloudflare_access_client_id>",
      "client_secret": "<cloudflare_access_client_secret>",
      "jwks_uri": "https://goldshore.cloudflareaccess.com/cdn-cgi/access/certs",
      "policies": {
        "bypass_webhook": "/webhook/github",
        "protected_paths": ["/admin", "/ai", "/oauth"]
      }
    },

    "resources": {
      "kv": {
        "sessions": "KV_SESSIONS",
        "cache": "KV_CACHE"
      },
      "queues": {
        "events": "goldshore-events",
        "dlq": "goldshore-dlq"
      },
      "r2": {
        "public": "goldshore-public",
        "logs": "goldshore-logs"
      },
      "d1": {
        "core": "goldshore-core"
      }
    }
  },

  "cloudflare_access": {
    "CF_ACCESS_CLIENT_ID": "<cloudflare_access_client_id>",
    "CF_ACCESS_CLIENT_SECRET": "<cloudflare_access_client_secret>"
  },

  "wrangler_bindings": {
    "kv.CONFIG_KV.id": {
      "source": "Cloudflare Dashboard or Wrangler CLI",
      "path": "Workers → KV → Create namespace",
      "url": "https://dash.cloudflare.com",
      "cli_example": "wrangler kv:namespace create CONFIG_KV --env production",
      "notes": "Use the returned namespace ID."
    },
    "kv.SESSIONS_KV.id": {
      "source": "Cloudflare Dashboard or Wrangler CLI",
      "path": "Workers → KV → Create namespace",
      "cli_example": "wrangler kv:namespace create SESSIONS_KV --env production"
    },
    "kv.GOOGLE_KV.id": {
      "source": "Cloudflare Dashboard or Wrangler CLI",
      "path": "Workers → KV → Create namespace",
      "cli_example": "wrangler kv:namespace create GOOGLE_KV --env production",
      "notes": "New binding for Google data."
    },
    "d1.DB.database_id": {
      "source": "Cloudflare Dashboard or Wrangler CLI",
      "path": "Workers → D1 → Create database",
      "cli_example": "wrangler d1 create goldshore-db"
    },
    "r2.ASSETS_BUCKET.bucket_name": {
      "source": "Cloudflare Dashboard or Wrangler CLI",
      "path": "R2 → Create bucket",
      "cli_example": "wrangler r2 bucket create goldshore-assets",
      "notes": "Use the exact bucket name you created."
    },
    "queues.TASKS_QUEUE.queue": {
      "source": "Cloudflare Dashboard or Wrangler CLI",
      "path": "Queues → Create queue",
      "cli_example": "wrangler queues create goldshore-tasks"
    }
  },

  "github_app": {
    "GH_APP_ID": "<github_app_id>",
    "GH_INSTALLATION_ID": "<github_installation_id>",
    "GH_APP_PRIVATE_KEY": "<pem_private_key>",
    "GH_WEBHOOK_SECRET": "<webhook_secret>",

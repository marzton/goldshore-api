  "auth": {
    "GOOGLE_CLIENT_ID": {
      "source": "Google Cloud Console",
      "path": "APIs & Services → Credentials → Create Credentials → OAuth Client ID",
      "url": "https://console.cloud.google.com/apis/credentials",
      "notes": "Web application type; add Authorized redirect URI."
    },
    "GOOGLE_CLIENT_SECRET": {
      "source": "Google Cloud Console",
      "path": "OAuth client → Download JSON or copy Secret"
    },
    "OAUTH_REDIRECT_URI": {
      "source": "Your app routing",
      "examples": ["https://admin.goldshore.org/auth/callback"],
      "notes": "Must exactly match provider console configuration."
    }
  },

  "turnstile": {
    "PUBLIC_TURNSTILE_SITE_KEY": "<turnstile_site_key>",
    "TURNSTILE_SECRET_KEY": "<turnstile_secret_key>"
  },

  "gateway": {
    "service_name": "goldshore-gateway",
    "default_model": "gpt-4o-mini",
    "route_policy": {
      "MY_ROUTE_RULE": "MY_ROUTE = 'goldshore-gateway-' + randomString(6..8)",
      "example": "dynamic/goldshore-gateway-s8x3ke"
    },
    "chat_template": {
      "example": {
        "code": "const resp = await client.chat.completions.create({ model: \"dynamic/MY_ROUTE\", messages:[ { role:\"user\", content:\"Can you help me?\" } ]});"
      }
    }
  },

  "routing": {
    "public_home": "https://goldshore.org",
    "admin_app": "https://admin.goldshore.org",
    "api_base": "https://api.goldshore.org",
    "routes": [
      "api.goldshore.org/*",
      "admin.goldshore.org/*",
      "services.goldshore.org/*",
      "gateway.goldshore.org/*"
    ]
  },

  "cors": {
    "allowed": [
      "https://goldshore.org",
      "https://www.goldshore.org",
      "https://admin.goldshore.org",
      "https://preview.goldshore.org",
      "http://localhost:5173",
      "http://127.0.0.1:5173"
    ]
  },

  "application": {
    "environment": "production",
    "origin": "https://goldshore.org",
    "portal_name": "Gold Shore Portal"
  },

  "empty_fields_map": {
    "cloudflare.api_token": "REQUIRED",
    "cloudflare.workers.edit_worker_token": "REQUIRED",
